# =============================================
# MiniMax API 配置
# =============================================

# MiniMax API Key（从 MiniMax 开放平台获取）
MINIMAX_API_KEY=your_api_key_here

# MiniMax API 基础地址（通常不需要修改）
MINIMAX_BASE_URL=https://api.minimaxi.com/v1

#使用的模型名称
MINIMAX_MODEL_NAME=minimax-text-01